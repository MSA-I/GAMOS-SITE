# Dependencies
node_modules/

# Build output
dist/
build/
.cache/

# Halls sub-app (Constitution §2.1) — track its build output so static
# deploy works after `git clone` without requiring a build step on the
# server. To re-build locally: `npm run build:halls` from repo root.
!halls/dist/
!halls/dist/**

# Workbench
.tmp/
*.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp

# Logs
*.log
npm-debug.log*

# Remotion (subproject manages its own build + heavy media)
remotion/out/
remotion/public/
remotion/node_modules/

# Source asset library — READ-ONLY, multi-GB, lives outside repo history.
# NEVER commit. The user produces videos / images here; the repo only ever
# carries the encoded outputs under `assets/`.
תמונות לאנימציית האתר/

# Heavy MP4 sources — stay LOCAL ONLY. The site never loads MP4 directly;
# the canvas frame renderer paints pre-extracted WebP frame sequences from
# `assets/frames/<scene>/` instead. Re-encode locally with `npm run encode:*`.
assets/video/

# IMPORTANT — the following directories ARE tracked in git (do NOT ignore):
#   assets/images/   brand mark, hero static, halls, lounge, gallery, maps
#   assets/img/      additional section graphics + icons
#   assets/frames/   30fps WebP frame sequences for canvas scrub (Hero +
#                    Culinary; sizes have been bumped 2026-06-02 per user
#                    direction — Hero ≈ 60MB, Culinary ≈ 22MB)
#   assets/fonts/    self-hosted WOFF2 (Rubik + Heebo + Playfair)
#   assets/vendor/   GSAP + ScrollToPlugin (self-hosted, no CDN)
# These are the production payload. If git ever starts ignoring them, the
# site stops rendering.

# AgentDB / ruflo local state
ruvector.db
.claude-cache/
.claude/
