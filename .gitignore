# Dependencies
node_modules/

# Build output
dist/
build/
.cache/

# Cloudflare Pages staging dir — assembled fresh by scripts/deploy-cloudflare.mjs
# on every `npm run deploy:cf*`. Never committed; rebuilt each run.
_site/

# Halls sub-app (Constitution §2.1) — track its build output so static
# deploy works after `git clone` without requiring a build step on the
# server. To re-build locally: `npm run build:halls` from repo root.
!halls/dist/
!halls/dist/**

# Rooms sub-app (Constitution §2.1, third route — phantom-style image wall).
# Same rationale as halls: track the built artifact so static deploy works
# after `git clone`. Re-build locally: `npm run build:rooms` from repo root.
!rooms/dist/
!rooms/dist/**

# Rooms-lab EXPERIMENT (sandbox, pending approval) — track the built gallery
# copy so the door→gallery handoff works on refresh / fresh checkout / another
# machine (the global `dist/` rule above would otherwise hide it → full-page
# 404 when the gallery URL loads). Re-build locally: `npm run build:rooms-lab`.
!rooms-lab/gallery/dist/
!rooms-lab/gallery/dist/**

# Figma export pipeline output — generated by `npm run export:figma`
# (tokens.json + heavy media copies incl. the ~20MB hero subject.png). Computed
# artifact, never committed; the runbook (figma-export/README.md) IS tracked.
figma-export/tokens.json
figma-export/media/
figma-export/site-images/

# Workbench
.tmp/
*.local

# OS
.DS_Store
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp

# Logs
*.log
npm-debug.log*

# Remotion (subproject manages its own build + heavy media)
remotion/out/
remotion/public/
remotion/node_modules/

# Source asset library — READ-ONLY, multi-GB, lives outside repo history.
# NEVER commit. The user produces videos / images here; the repo only ever
# carries the encoded outputs under `assets/`.
# 2026-06-09: relocated to ../GAMOS-DOCS/ — entry left here as belt-and-braces
# in case the folder is ever recreated inside the repo by mistake.
תמונות לאנימציית האתר/

# Heavy MP4 sources — stay LOCAL ONLY. The site never loads MP4 directly;
# the canvas frame renderer paints pre-extracted WebP frame sequences from
# `assets/frames/<scene>/` instead. Re-encode locally with `npm run encode:*`.
assets/video/

# Source asset workbench (originals + superseded sets). Encoder reads from
# here and writes to assets/images/ — only the encoded outputs ship.
assets/_src/

# Orphaned hero frame sequence (155MB). The hero migrated to the v10 cinematic
# scroll scene (§3, LOCKED 2026-06-15) which paints layered PNG/WebP from
# assets/images/hero-scene/ — it no longer uses canvas frames. These frames
# have zero live references; untracked 2026-06-15 to keep the deploy lean.
# Re-encode manually (no npm script) only if the v9 canvas hero ever returns.
assets/frames/hero/

# IMPORTANT — the following directories ARE tracked in git (do NOT ignore):
#   assets/images/   brand mark, hero static, halls, lounge, gallery, maps
#   assets/img/      additional section graphics + icons
#   assets/frames/   30fps WebP frame sequences for canvas scrub. Only
#                    assets/frames/culinary + culinary-mobile remain in use
#                    (the #culinary scrub); hero frames untracked above.
#   assets/fonts/    self-hosted WOFF2 (Rubik + Heebo + Playfair)
#   assets/vendor/   GSAP + ScrollToPlugin (self-hosted, no CDN)
# These are the production payload. If git ever starts ignoring them, the
# site stops rendering.

# AgentDB / ruflo local state
ruvector.db
.claude-cache/
.claude/

# Agent-tooling scratch state — local only, never part of the site payload.
# .swarm/ + claude-flow.config.json: claude-flow / ruflo orchestration state.
# index.html.artifact.json: Open Design artifact sidecar.
.swarm/
claude-flow.config.json
*.artifact.json

# Hero-lab QA + diagnostic scratch — never committed (§6 rule 6). The lab page
# + assets + build-assets.mjs ARE tracked (porting reference); the comparison /
# QA scripts and their screenshot outputs are local-only.
hero-lab/scripts/__shots__/
hero-lab/scripts/compare-*.mjs
hero-lab/scripts/qa-*.mjs
hero-lab/scripts/frame-diff-*.mjs

# Rooms-lab QA screenshots — scratch, re-shoot on demand (the qa script itself
# IS tracked as part of the experiment deliverable).
rooms-lab/scripts/__shots__/

# Removed reference/export artifacts (deleted 2026-06-22) — regenerable, kept
# out of the repo so they don't creep back. Content is live in index.html;
# QA screenshots re-shoot on demand; FIND hero source lives off-repo.
exports/
docs/qa-screenshots/
docs/reference-assets/
