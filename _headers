# Cloudflare Pages headers — GAMOS-SITE (Constitution §14, host = Cloudflare Pages).
# Syntax: a path pattern line, followed by indented "Header: value" lines.
# Cloudflare applies the FIRST matching block per header; order most-specific first.
#
# Caching strategy:
#   - Vite-hashed sub-app assets (…-<hash>.js/.css) are content-addressed → immutable, 1y.
#   - Self-hosted vendor libs + fonts + images are content-stable → 1y immutable
#     (re-encodes change the path or are intentional deploys).
#   - HTML is the mutable entry → short cache + revalidate so content edits go live fast.

# ---- Sub-app build artifacts (Vite hashed filenames) ------------------------
/halls/dist/assets/*
  Cache-Control: public, max-age=31536000, immutable
/rooms/dist/assets/*
  Cache-Control: public, max-age=31536000, immutable

# ---- Self-hosted vendor libraries (GSAP, Leaflet, paper-shaders) ------------
/assets/vendor/*
  Cache-Control: public, max-age=31536000, immutable

# ---- Fonts (self-hosted WOFF2) ----------------------------------------------
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# ---- Images (REVALIDATING — 2026-06-25) -------------------------------------
# Gallery images are human-named (buffet/01.full.webp …) and DO get replaced in
# place when a section is redesigned (e.g. the #buffet "bands" redesign reused
# 01–13.*). `immutable` made those updates invisible to returning visitors for a
# year. SWR keeps them effectively instant (served from cache while a background
# revalidate runs) but lets content edits propagate within a day. Egress is free
# on Cloudflare Pages (§14) so the extra conditional requests cost nothing.
/assets/images/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
# Frames + video are heavy, numerous, and only change on a deliberate re-encode
# (which we cache-bust by version) → keep immutable.
/assets/frames/*
  Cache-Control: public, max-age=31536000, immutable
/assets/video/*
  Cache-Control: public, max-age=31536000, immutable

# ---- Core CSS/JS (vanilla, unhashed — revalidate so edits ship) -------------
/css/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
/js/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400

# ---- Baseline security headers for every response --------------------------
# (CSP is intentionally omitted for now — a report-only policy is a tracked
#  follow-up; adding an enforcing CSP without testing would risk blocking the
#  self-hosted GSAP/Leaflet/paper-shaders + the React sub-apps.)
/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: SAMEORIGIN
  Permissions-Policy: geolocation=(), microphone=(), camera=()

# ---- HTML entry documents (short cache, always revalidate) ------------------
/
  Cache-Control: public, max-age=300, must-revalidate
/*.html
  Cache-Control: public, max-age=300, must-revalidate
