{
  "name": "gamos-site",
  "version": "1.0.0",
  "description": "אתר עברית-RTL יוקרתי למתחם האירועים והריזורט גאמוס (מעלה אדומים) — HTML/CSS/JS וונילה עם hero קולנועי scroll-pinned (GSAP v10), פלוס תת-אפליקציות React/Vite לאולמות ולחדרים (Constitution §2.1). אין framework/bundler בליבה.",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:fast": "npx --yes serve . -p 8000 -L",
    "dev:python": "python -m http.server 8000",
    "dev:halls": "cd halls && npm run dev -- --port 5173",
    "build:halls": "cd halls && npm install && npm run build",
    "dev:rooms": "cd rooms && npm run dev -- --port 5174",
    "build:rooms": "cd rooms && npm install && npm run build",
    "build:mobile": "node scripts/build-mobile-index.mjs",
    "build": "npm run build:mobile && npm run build:halls && npm run build:rooms",
    "deploy:cf": "node scripts/deploy-cloudflare.mjs",
    "deploy:cf:prod": "node scripts/deploy-cloudflare.mjs --prod",
    "deploy:cf:stage": "node scripts/deploy-cloudflare.mjs --stage-only",
    "encode:hero": "node scripts/encode-frames.mjs hero",
    "encode:culinary": "node scripts/encode-frames.mjs culinary",
    "encode:all": "node scripts/encode-frames.mjs hero culinary",
    "encode:images": "node scripts/encode-images.mjs",
    "encode:rooms-door": "node scripts/encode-rooms-door.mjs",
    "extract:shabbat-tints": "node scripts/extract-shabbat-tints.mjs",
    "lighthouse": "npx --yes lighthouse http://localhost:8000 --view --preset=desktop"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MSA-I/GAMOS-SITE.git"
  },
  "homepage": "https://github.com/MSA-I/GAMOS-SITE#readme",
  "bugs": {
    "url": "https://github.com/MSA-I/GAMOS-SITE/issues"
  },
  "license": "UNLICENSED",
  "author": "GAMOS",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@imgly/background-removal-node": "^1.4.5",
    "node-vibrant": "^4.0.0",
    "sharp": "^0.34.5",
    "three": "^0.184.0"
  }
}
